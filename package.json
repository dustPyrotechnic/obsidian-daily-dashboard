{
    "name": "obsidian-daily-dashboard",
    "version": "0.1.0",
    "description": "AI-powered daily dashboard code block for Obsidian daily notes.",
    "main": "main.js",
    "type": "module",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "version": "node version-bump.mjs && git add manifest.json versions.json"
    },
    "keywords": [
        "obsidian",
        "obsidian-plugin",
        "daily-notes",
        "dashboard"
    ],
    "author": "dustPyrotechnic",
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^16.11.6",
        "esbuild": "0.25.5",
        "obsidian": "latest",
        "tslib": "2.4.0",
        "typescript": "^5.8.3"
    }
}
